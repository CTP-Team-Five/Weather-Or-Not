# Supabase (optional — app works without these, falls back to localStorage)
# Both vars are intentionally NEXT_PUBLIC_ because the Supabase anon key is
# safe to expose in the browser (row-level security enforces access control).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
