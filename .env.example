# ── Supabase (optional — app falls back to localStorage) ──────────────────
# The anon key is safe to expose in the browser; row-level security
# enforces access control.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Site metadata ─────────────────────────────────────────────────────────
# Used for OG/Twitter tags, metadataBase, and the Nominatim User-Agent
# so OpenStreetMap sees a real contact URL.
NEXT_PUBLIC_SITE_URL=https://weatherornot.app

# ── Nominatim contact (overrides site URL as the UA string) ───────────────
# OSM's usage policy requires a real contact. Set this OR the site URL.
NEXT_PUBLIC_NOMINATIM_CONTACT=mailto:you@example.com
